{
  "name": "muscloot-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "generate:auth:buf": "buf generate buf.build/qkitzero-org/auth-service",
    "generate:user:buf": "buf generate buf.build/qkitzero-org/user-service",
    "generate:workout:buf": "buf generate buf.build/qkitzero-org/workout-service",
    "generate:buf": "npm run generate:auth:buf && npm run generate:user:buf && npm run generate:workout:buf",
    "generate:auth:openapi": "swagger2openapi ./gen/auth/v1/auth.swagger.json -o ./gen/auth/v1/auth.openapi.json",
    "generate:user:openapi": "swagger2openapi ./gen/user/v1/user.swagger.json -o ./gen/user/v1/user.openapi.json",
    "generate:workout:openapi": "swagger2openapi ./gen/workout/v1/workout.swagger.json -o ./gen/workout/v1/workout.openapi.json",
    "generate:set:openapi": "swagger2openapi ./gen/set/v1/set.swagger.json -o ./gen/set/v1/set.openapi.json",
    "generate:exercise:openapi": "swagger2openapi ./gen/exercise/v1/exercise.swagger.json -o ./gen/exercise/v1/exercise.openapi.json",
    "generate:muscle:openapi": "swagger2openapi ./gen/muscle/v1/muscle.swagger.json -o ./gen/muscle/v1/muscle.openapi.json",
    "generate:openapi": "npm run generate:auth:openapi && npm run generate:user:openapi && npm run generate:workout:openapi && npm run generate:set:openapi && npm run generate:exercise:openapi && npm run generate:muscle:openapi",
    "generate:auth:schema": "openapi-typescript ./gen/auth/v1/auth.openapi.json -o ./gen/auth/v1/auth.schema.ts",
    "generate:user:schema": "openapi-typescript ./gen/user/v1/user.openapi.json -o ./gen/user/v1/user.schema.ts",
    "generate:workout:schema": "openapi-typescript ./gen/workout/v1/workout.openapi.json -o ./gen/workout/v1/workout.schema.ts",
    "generate:set:schema": "openapi-typescript ./gen/set/v1/set.openapi.json -o ./gen/set/v1/set.schema.ts",
    "generate:exercise:schema": "openapi-typescript ./gen/exercise/v1/exercise.openapi.json -o ./gen/exercise/v1/exercise.schema.ts",
    "generate:muscle:schema": "openapi-typescript ./gen/muscle/v1/muscle.openapi.json -o ./gen/muscle/v1/muscle.schema.ts",
    "generate:schema": "npm run generate:auth:schema && npm run generate:user:schema && npm run generate:workout:schema && npm run generate:set:schema && npm run generate:exercise:schema && npm run generate:muscle:schema",
    "generate:all": "npm run generate:buf && npm run generate:openapi && npm run generate:schema",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.6",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "swagger2openapi": "^7.0.8",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
